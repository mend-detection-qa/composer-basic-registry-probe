{
    "name": "mend-detection-qa/composer-basic-registry-probe",
    "description": "Minimal Composer probe: basic Packagist registry detection test.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "monolog/monolog": "^3.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}